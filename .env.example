# ============================================================
# AI-News 环境变量模板
# 使用：cp .env.example .env  然后填入真实值
# 注意：.env 已加入 .gitignore，切勿提交
# ============================================================

# ---------- 应用 ----------
APP_ENV=dev                       # dev | prod
APP_NAME=ai-news
APP_HOST=0.0.0.0
APP_PORT=8001                 # 宿主机映射端口；8000 被占用时可改为 8001 等
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
TIMEZONE=Asia/Shanghai

# ---------- 数据库 ----------
POSTGRES_USER=ainews
POSTGRES_PASSWORD=ainews_pass_change_me
POSTGRES_DB=ainews
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://ainews:ainews_pass_change_me@postgres:5432/ainews

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------- LLM ----------
# 支持 openai | anthropic | deepseek | ollama 等 litellm 覆盖的提供商
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=                  # 可选：自建代理/中转地址；Ollama 时填 http://host:11434/v1
# ANTHROPIC_API_KEY=

# DeepSeek 示例（LLM 分析用 DeepSeek 时）：
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek/deepseek-chat
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# OPENAI_API_KEY=sk-your-openai-key-here   # 仍可保留，供 Embedding 语义去重使用

LLM_MONTHLY_BUDGET_USD=30
LLM_TIMEOUT_SECONDS=60

# ---------- Embedding ----------
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_SIMILARITY_THRESHOLD=0.92
EMBEDDING_DEDUP_DAYS=7

# ---------- Dashboard 认证 ----------
ADMIN_PASSWORD=changeme-admin-pass
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRE_HOURS=24
AUTH_ENABLED=true

# ---------- 飞书 ----------
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id
FEISHU_SECRET=                    # 机器人签名密钥（可选但推荐）

# ---------- 推送策略 ----------
DAILY_DIGEST_CRON=30 8 * * *      # 每日 08:30
WEEKLY_DIGEST_CRON=0 9 * * 1      # 每周一 09:00
COLLECT_CRON=*/30 * * * *         # 每 30 分钟抓取一次
INSTANT_PUSH_CRON=*/5 * * * *     # 每 5 分钟扫描即时推送
INSTANT_PUSH_MIN_SCORE=9
DAILY_PUSH_MIN_SCORE=7
DAILY_PUSH_TOP_N=10
QUIET_HOURS_START=22:00
QUIET_HOURS_END=07:30

# ---------- 用户偏好（逗号分隔 key=weight） ----------
USER_INTERESTS=LLM=1.0,Agent=0.9,RAG=0.8,Multimodal=0.8,AI-Infra=0.7

# ---------- 其他可选凭证 ----------
# GITHUB_TOKEN=
# HTTP_PROXY=
# HTTPS_PROXY=
